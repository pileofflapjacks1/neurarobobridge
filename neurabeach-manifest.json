{
  "manifest_version": "1.0.0",
  "name": "neurarobobridge",
  "display_name": "NeuraRoboBridge",
  "version": "0.3.0",
  "description": "BCI-to-robot middleware: high-level neural intentions → safe robot commands. Simulator arm/humanoid, skill runtime, policy plugins, NeuralBridge adapter. Computer-side / research only — not implant software.",
  "safety_class": "research_only",
  "runtime": "library",
  "inputs": [
    "synthetic",
    "class_label",
    "switch_binary",
    "multichannel_stream"
  ],
  "outputs": ["ui_only", "file_export", "websocket"],
  "hardware": [
    "synthetic",
    "generic_intent",
    "websocket_intent",
    "neuralink_sdk_future"
  ],
  "permissions": ["none", "network_local"],
  "dof": "high_dof",
  "latency_class": "realtime",
  "platforms": ["macos", "windows", "linux", "web"],
  "calibration": "optional",
  "entrypoint": "https://neurarobobridge.vercel.app",
  "repository": "https://github.com/pileofflapjacks1/neurarobobridge",
  "suite_role": "middleware",
  "depends_on": [],
  "adapter_maturity": "simulator_only",
  "banned_claims": true
}
